import {
  StrictMode,
} from "react";

import {
  createRoot,
} from "react-dom/client";

import App from "./App";


const rootElement =
  document.getElementById("root");

if (!rootElement) {
  throw new Error(
    'The HTML element with id "root" is missing.',
  );
}


createRoot(rootElement).render(
  <StrictMode>
    <App />
  </StrictMode>,
);
